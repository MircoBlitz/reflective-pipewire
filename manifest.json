{
  "Name": "Reflective PipeWire",
  "Author": "MircoBlitz",
  "Version": "0.2.7",
  "Description": "Reactive PipeWire Audio Suite for OpenDeck. Mute toggle, volume knobs, volume display, and volume buttons — all with real-time state sync.",
  "Icon": "icons/plugin",
  "Category": "RefPipe Audio",
  "CodePaths": {
    "x86_64-unknown-linux-gnu": "x86_64-unknown-linux-gnu/reflective-pipewire",
    "aarch64-unknown-linux-gnu": "aarch64-unknown-linux-gnu/reflective-pipewire"
  },
  "CodePathLin": "x86_64-unknown-linux-gnu/reflective-pipewire",
  "OS": [
    {
      "Platform": "linux"
    }
  ],
  "Actions": [
    {
      "Name": "Mute Toggle",
      "UUID": "de.mircoblitz.reflective-pipewire.mute-toggle",
      "Icon": "icons/mic",
      "Tooltip": "Toggle mute on any source/sink. State syncs across all buttons in real-time.",
      "Controllers": ["Keypad"],
      "SupportedInMultiActions": true,
      "PropertyInspectorPath": "propertyInspector/mute_toggle.html",
      "States": [
        { "Image": "icons/mic", "Name": "Unmuted" },
        { "Image": "icons/mic_deactivated", "Name": "Muted" }
      ]
    },
    {
      "Name": "Volume Knob",
      "UUID": "de.mircoblitz.reflective-pipewire.volume-knob",
      "Icon": "icons/volume_knob",
      "Tooltip": "Encoder: rotate to change volume, press to toggle mute.",
      "Controllers": ["Encoder"],
      "SupportedInMultiActions": false,
      "PropertyInspectorPath": "propertyInspector/volume_knob.html",
      "States": [
        { "Image": "icons/volume_knob", "Name": "Default" }
      ]
    },
    {
      "Name": "Volume Display",
      "UUID": "de.mircoblitz.reflective-pipewire.volume-display",
      "Icon": "icons/volume_display",
      "Tooltip": "Read-only volume display that syncs with the system in real-time.",
      "Controllers": ["Keypad"],
      "SupportedInMultiActions": false,
      "PropertyInspectorPath": "propertyInspector/volume_display.html",
      "States": [
        { "Image": "icons/volume_display", "Name": "Default" }
      ]
    },
    {
      "Name": "Volume Up",
      "UUID": "de.mircoblitz.reflective-pipewire.volume-up",
      "Icon": "icons/volume_up",
      "Tooltip": "Press to increase volume by a configurable step.",
      "Controllers": ["Keypad"],
      "SupportedInMultiActions": true,
      "PropertyInspectorPath": "propertyInspector/volume_up.html",
      "States": [
        { "Image": "icons/volume_up", "Name": "Default" }
      ]
    },
    {
      "Name": "Volume Down",
      "UUID": "de.mircoblitz.reflective-pipewire.volume-down",
      "Icon": "icons/volume_down",
      "Tooltip": "Press to decrease volume by a configurable step.",
      "Controllers": ["Keypad"],
      "SupportedInMultiActions": true,
      "PropertyInspectorPath": "propertyInspector/volume_down.html",
      "States": [
        { "Image": "icons/volume_down", "Name": "Default" }
      ]
    }
  ]
}
